# PermitPal — Environment Variables
# Copy to .env and fill in your values — NEVER commit secrets

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────
# DATABASE — MySQL 8.0
# ─────────────────────────────────────────
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=permitpal;User=permitpal;Password=your_password;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;SslMode=Preferred;

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
Jwt__SecretKey=your-secret-key-minimum-32-characters-long
Jwt__Issuer=permitpal-api
Jwt__Audience=permitpal-app
Jwt__AccessTokenExpiryMinutes=30
Jwt__RefreshTokenExpiryDays=30

# ─────────────────────────────────────────
# REDIS — Hangfire + cache
# ─────────────────────────────────────────
Redis__ConnectionString=localhost:6379

# ─────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────
Stripe__SecretKey=sk_test_...
Stripe__PublishableKey=pk_test_...
Stripe__WebhookSecret=whsec_...
# Plan price IDs (create in Stripe dashboard)
Stripe__PriceId__Solo=price_...
Stripe__PriceId__Host=price_...
Stripe__PriceId__Operator=price_...

# ─────────────────────────────────────────
# TWILIO — SMS alerts
# ─────────────────────────────────────────
Twilio__AccountSid=AC...
Twilio__AuthToken=your-auth-token
Twilio__FromNumber=+1...

# ─────────────────────────────────────────
# RESEND — Email
# ─────────────────────────────────────────
Resend__ApiKey=re_...
Email__FromAddress=alerts@permitpal.com
Email__FromName=PermitPal

# ─────────────────────────────────────────
# CLOUDFLARE R2 — Document storage
# ─────────────────────────────────────────
Storage__R2__AccountId=your-cloudflare-account-id
Storage__R2__AccessKeyId=your-r2-access-key
Storage__R2__SecretAccessKey=your-r2-secret
Storage__R2__BucketName=permitpal-documents
Storage__R2__PublicUrl=https://docs.permitpal.com

# ─────────────────────────────────────────
# GOOGLE MAPS — Geocoding + zoning
# ─────────────────────────────────────────
GoogleMaps__ApiKey=your-google-maps-api-key
# Enable: Geocoding API, Maps JavaScript API, Places API

# ─────────────────────────────────────────
# ANTHROPIC CLAUDE — Rule change summaries
# ─────────────────────────────────────────
Anthropic__ApiKey=sk-ant-...
Anthropic__Model=claude-haiku-4-5-20251001
# Prompt: summarise this regulatory change in plain English for an Airbnb host

# ─────────────────────────────────────────
# HANGFIRE — Background jobs
# ─────────────────────────────────────────
Hangfire__DashboardPath=/hangfire
Hangfire__WorkerCount=5
# Job schedule (cron expressions)
Jobs__PermitRenewalAlert=0 8 * * *        # Daily 8am
Jobs__NightCapAlert=0 9 * * *             # Daily 9am
Jobs__ICalSync=0 */4 * * *               # Every 4 hours
Jobs__RegulatoryMonitor=0 2 * * *         # Nightly 2am
Jobs__EuRegistrationCheck=0 3 * * 1       # Weekly Monday 3am
Jobs__ComplianceScore=0 1 * * *           # Nightly 1am
Jobs__VicLevyReminder=0 10 1 1,4,7,10 *  # Quarterly

# ─────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────
Sentry__Dsn=https://...@sentry.io/...
PostHog__ApiKey=phc_...
PostHog__Host=https://eu.posthog.com      # EU instance for GDPR

# ─────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────
Features__EuWizardEnabled=true
Features__AuNswEnabled=true
Features__AuVictoriaEnabled=true
Features__AuWaEnabled=true
Features__AuBrisbaneEnabled=false         # Enable when mid-2026 laws pass
Features__UsTop10Enabled=false            # Enable in Phase 4
Features__ZoningCheckEnabled=false        # Enable when GIS API integrated
