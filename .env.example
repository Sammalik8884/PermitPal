# ============================================================
# PermitPal Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Application ────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── Database (MySQL) ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=permitpal
MYSQL_USER=permitpal
MYSQL_PASSWORD=permitpal_dev_password
ConnectionStrings__DefaultConnection=Server=mysql;Port=3306;Database=permitpal;User=permitpal;Password=permitpal_dev_password;

# ─── Redis ─────────────────────────────────────────────────
Redis__ConnectionString=redis:6379

# ─── JWT Authentication ────────────────────────────────────
Jwt__Secret=your-super-secret-jwt-key-at-least-32-chars-long
Jwt__Issuer=PermitPal
Jwt__Audience=PermitPal
Jwt__ExpirationMinutes=60
Jwt__RefreshExpirationDays=7

# ─── Object Storage (Cloudflare R2 / S3-compatible) ────────
Storage__Endpoint=https://your-account-id.r2.cloudflarestorage.com
Storage__AccessKey=your-r2-access-key
Storage__SecretKey=your-r2-secret-key
Storage__BucketName=permitpal-documents
Storage__Region=auto

# ─── Email (Resend) ───────────────────────────────────────
Email__ApiKey=re_your_resend_api_key
Email__FromAddress=noreply@permitpal.com
Email__FromName=PermitPal

# ─── SMS (Twilio) ─────────────────────────────────────────
Sms__AccountSid=your_twilio_account_sid
Sms__AuthToken=your_twilio_auth_token
Sms__FromNumber=+1234567890

# ─── Stripe Billing ───────────────────────────────────────
Stripe__SecretKey=sk_test_your_stripe_secret_key
Stripe__PublishableKey=pk_test_your_stripe_publishable_key
Stripe__WebhookSecret=whsec_your_webhook_secret
Stripe__PriceIdSolo=price_solo_id
Stripe__PriceIdHost=price_host_id
Stripe__PriceIdOperator=price_operator_id
Stripe__PriceIdManager=price_manager_id

# ─── Hangfire (Background Jobs) ───────────────────────────
Hangfire__DashboardEnabled=true
Hangfire__DashboardUsername=admin
Hangfire__DashboardPassword=admin

# ─── Frontend (Vite) ──────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=PermitPal
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Logging ──────────────────────────────────────────────
Serilog__MinimumLevel=Information
Serilog__WriteTo__Seq__ServerUrl=http://localhost:5341

# ─── CORS ─────────────────────────────────────────────────
Cors__AllowedOrigins=http://localhost:3000,http://localhost:5173
